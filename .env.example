# 复制为 .env 并填入真实值。.env 已被 .gitignore，绝不提交。

# DeepSeek（OpenAI 兼容端点）
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_JSON_MODEL=deepseek-v4-flash
DEEPSEEK_TOOL_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled

# StepFun（如需切回，把 LLM_PROVIDER 改成 stepfun）
STEPFUN_API_KEY=sk-your-stepfun-key-here

# 人格模型：默认 step-3.7-flash（推理、慢但新）；想快稳切 step-2-16k
STEPFUN_MODEL=step-3.7-flash
STEPFUN_REASONING=low

# 计算师联网检索（可选，不配会自动降级为纯 prompt）
SEARCH_ENABLED=0
TAVILY_API_KEY=
